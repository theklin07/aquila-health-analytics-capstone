      <aliases enabled='yes' />
      <column caption='No-Show Rate' datatype='real' default-format='p0.0%' name='[Calculation_2425931106738176]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [status] = &quot;No-Show&quot; THEN 1 ELSE 0 END) / COUNT([appointment_id])' />
      </column>
      <column caption='Cancellation Rate' datatype='real' default-format='p0.0%' name='[Calculation_2425931107016705]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [status] = &quot;Cancelled&quot; THEN 1 ELSE 0 END) / COUNT([appointment_id])' />
      </column>
      <column caption='Provider Utilization Rate' datatype='real' default-format='p0.0%' name='[Calculation_2425931107172354]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([appointment_id]) / SUM([weekly_capacity_slots])' />
      </column>
