    <worksheet name='Cancellation Rate'>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_appointments+ (Aquila_Synthetic_Dataset)' name='federated.13qfqsk0nn5p6w145kzx91pq578u' />
          </datasources>
          <datasource-dependencies datasource='federated.13qfqsk0nn5p6w145kzx91pq578u'>
            <column caption='Cancellation Rate' datatype='real' default-format='p0.0%' name='[Calculation_2425931107016705]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [status] = &quot;Cancelled&quot; THEN 1 ELSE 0 END) / COUNT([appointment_id])' />
            </column>
            <column caption='Appointment Day Of Week' datatype='string' name='[appointment_day_of_week]' role='dimension' type='nominal' />
            <column caption='Appointment Id' datatype='string' name='[appointment_id]' role='dimension' type='nominal' />
            <column caption='Appointment Type' datatype='string' name='[appointment_type]' role='dimension' type='nominal' />
            <column caption='Clinic Name' datatype='string' name='[clinic_name]' role='dimension' type='nominal' />
            <column-instance column='[appointment_type]' derivation='None' name='[none:appointment_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[clinic_name]' derivation='None' name='[none:clinic_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[specialty]' derivation='None' name='[none:specialty:nk]' pivot='key' type='nominal' />
            <column-instance column='[year]' derivation='None' name='[none:year:qk]' pivot='key' type='quantitative' />
