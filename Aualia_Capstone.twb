    <worksheet name='Provider Utilization Rate'>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_appointments+ (Aquila_Synthetic_Dataset)' name='federated.13qfqsk0nn5p6w145kzx91pq578u' />
          </datasources>
          <datasource-dependencies datasource='federated.13qfqsk0nn5p6w145kzx91pq578u'>
            <column caption='Provider Utilization Rate' datatype='real' default-format='p0.0%' name='[Calculation_2425931107172354]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([appointment_id]) / SUM([weekly_capacity_slots])' />
